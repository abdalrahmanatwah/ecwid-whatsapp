# ---- Server ----
PORT=3000
# How often (seconds) to check Ecwid for new orders. 60 = once a minute.
POLL_INTERVAL_SECONDS=60

# ---- Ecwid ----
# Your numeric Ecwid store ID (My Sales > Dashboard, or Settings).
ECWID_STORE_ID=
# Secret API token of your Ecwid custom app (starts with "secret_").
# Needs scopes: read_orders, update_orders, read_store_profile
ECWID_API_TOKEN=

# What to set the order to when the customer CONFIRMS (fulfillment status).
# Options: AWAITING_PROCESSING, PROCESSING, SHIPPED, DELIVERED, READY_FOR_PICKUP, OUT_FOR_DELIVERY, CUSTOM_FULFILLMENT_STATUS_1..3
CONFIRM_FULFILLMENT_STATUS=PROCESSING
# What to set the order to when the customer CANCELS (payment status).
# Options: CANCELLED, INCOMPLETE, REFUNDED, CUSTOM_PAYMENT_STATUS_1..3
CANCEL_PAYMENT_STATUS=CANCELLED

# ---- WhatsApp Cloud API (Meta) ----
GRAPH_VERSION=v21.0
# Phone Number ID from Meta > WhatsApp > API Setup (NOT the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=
# Permanent access token (System User token recommended).
WHATSAPP_ACCESS_TOKEN=
# Any random string you choose; you'll enter the SAME value in Meta's webhook config.
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
# The approved template's name and language code (e.g. en, en_US, ar).
WHATSAPP_TEMPLATE_NAME=order_confirmation
WHATSAPP_TEMPLATE_LANG=ar

# ---- Phone normalization ----
# Default country calling code (no +). Egypt = 20.
DEFAULT_COUNTRY_CODE=20

# ---- Optional: notify the store owner on every reply ----
# Owner WhatsApp number in international format, digits only (e.g. 2010xxxxxxxx).
# Note: only delivers if the owner has messaged the business number in the last 24h,
# otherwise it is silently skipped. The Ecwid status change is the reliable signal.
MERCHANT_WHATSAPP=

# ---- Bosta auto-shipping (optional; leave BOSTA_API_KEY blank to disable) ----
# API key from your Bosta dashboard → API Integration page.
BOSTA_API_KEY=
# Use the STAGING url first to test without creating real shipments, then switch.
# Staging: https://stg-app.bosta.co/api/v2   Production: https://app.bosta.co/api/v2
BOSTA_BASE_URL=https://app.bosta.co/api/v2
# Status to set in Ecwid once the Bosta shipment is created.
SHIPPED_FULFILLMENT_STATUS=SHIPPED
# Minutes to wait after a customer CONFIRMS before creating the Bosta shipment.
# This is the grace window in which a customer can still cancel. Default 60.
SHIP_DELAY_MINUTES=60

# ---- Address translation for Bosta (optional) ----
# Anthropic API key — used only to translate English street addresses to Arabic.
# Leave blank to send addresses unchanged. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
